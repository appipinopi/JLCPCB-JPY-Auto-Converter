{
  "manifest_version": 3,
  "name": "JLCPCB JPY Auto Converter Pro",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://api.forexrateapi.com/*", "https://*.jlcpcb.com/*"],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*.jlcpcb.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
